# Editor / OS
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# Logs / build artifacts (none expected, but defensive)
*.log
node_modules/
dist/
.cache/

# Helper / private files that should never be in git
*_DO_NOT_PUBLISH*/
*.env
*.env.local

# Defensive blocklist — never publish these even if accidentally placed under site/
**/certbot/
**/private_key.json
**/*.pem
**/*.key
**/.env

# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example
.env*
!.env.example
