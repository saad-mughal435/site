{
  "name": "saadm.dev",
  "version": "6.0.0",
  "private": true,
  "description": "Personal portfolio for Muhammad Saad - Automation & Software Developer (backend, ERP/MES). Static site (HTML + self-hosted React + vanilla CSS) on Cloudflare Workers static assets.",
  "homepage": "https://saadm.dev/",
  "repository": {
    "type": "git",
    "url": "https://github.com/saad-mughal435/site.git"
  },
  "bugs": {
