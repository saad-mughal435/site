  },
  "author": {
    "name": "Muhammad Saad",
    "email": "saad@saadm.dev",
    "url": "https://saadm.dev/"
  },
  "license": "MIT",
  "keywords": [
    "portfolio",
    "personal-website",
    "developer-portfolio",
    "react",
    "python",
    "fastapi",
    "java",
    "spring-boot",
    "n8n",
    "n8n-node",
    "typescript",
    "workflow-automation",
    "jwt",
    "mongodb",
    "automation-engineer",
    "erp",
    "mes",
    "oee",
    "manufacturing-software",
    "uae-developer",
    "open-to-relocate",
    "saad-mughal"
  ],
  "scripts": {
    "dev": "python -m http.server 8000 --bind 127.0.0.1",
    "build": "vite build && node scripts/compose.mjs",
    "serve": "python -m http.server 8000 --bind 127.0.0.1",
    "start": "python -m http.server 8000 --bind 127.0.0.1",
    "build:appcss": "tailwindcss -c tailwind.config.js -i tailwind.app.css -o app/css/tailwind.css --minify",
    "format": "prettier --write \"**/*.{html,css,js,json,md}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{html,css,js,json,md}\" --ignore-path .gitignore",
    "validate": "echo \"Static site - no build step. Validation runs in CI.\"",
    "preview": "echo \"Open http://127.0.0.1:8000 after running 'npm run dev'\""
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "prettier": "^3.3.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "gsap": "^3.15.0",
    "lenis": "^1.3.23",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
