{
  "name": "Lahza — a moment a day",
  "short_name": "Lahza",
  "description": "AI-augmented personal journaling and mood tracking. A daily prompt, a few sentences, and Claude surfaces the patterns.",
  "start_url": "/lahza/",
  "scope": "/lahza/",
  "id": "/lahza/",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui"],
  "orientation": "portrait",
  "background_color": "#1c1936",
  "theme_color": "#1c1936",
  "lang": "en",
  "dir": "ltr",
  "categories": ["lifestyle", "health", "productivity"],
  "icons": [
    { "src": "/lahza/icons/icon.svg", "type": "image/svg+xml", "sizes": "any", "purpose": "any" },
    { "src": "/lahza/icons/icon-192.png", "type": "image/png", "sizes": "192x192", "purpose": "any" },
    { "src": "/lahza/icons/icon-512.png", "type": "image/png", "sizes": "512x512", "purpose": "any" },
    { "src": "/lahza/icons/icon-maskable-512.png", "type": "image/png", "sizes": "512x512", "purpose": "maskable" }
  ],
  "shortcuts": [
    {
      "name": "New entry",
      "short_name": "Compose",
      "description": "Write today's moment",
      "url": "/lahza/#compose",
      "icons": [{ "src": "/lahza/icons/icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "AI Coach",
      "short_name": "Coach",
      "description": "Chat with the AI Coach grounded in your journal",
      "url": "/lahza/#coach",
      "icons": [{ "src": "/lahza/icons/icon-192.png", "sizes": "192x192" }]
    }
  ]
}
