# Cloudflare Pages - HTTP headers
# https://developers.cloudflare.com/pages/configuration/headers/

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://unpkg.com https://cdn.jsdelivr.net https://cdn.tailwindcss.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://unpkg.com https://cdn.tailwindcss.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https://images.unsplash.com https://*.tile.openstreetmap.org https://*.basemaps.cartocdn.com https://unpkg.com; connect-src 'self' https://formsubmit.co https://huggingface.co https://*.hf.co https://cdn.jsdelivr.net https://cloudflareinsights.com https://static.cloudflareinsights.com; worker-src 'self' blob:; child-src 'self' blob:; frame-ancestors 'self'; base-uri 'self'; form-action 'self' https://formsubmit.co; object-src 'none'

# Short cache + revalidate for project JS/CSS - these files don't have fingerprints in
# their names so they need to revalidate often. (Was: max-age=31536000 immutable -
# which locked stale code in browser caches for up to a year. Don't do that.)
/app/css/*
  Cache-Control: public, max-age=300, must-revalidate
/app/js/*
  Cache-Control: public, max-age=300, must-revalidate
/app/api/qc/assets/*
  Cache-Control: public, max-age=31536000, immutable
/b2c/css/*
  Cache-Control: public, max-age=300, must-revalidate
/b2c/js/*
  Cache-Control: public, max-age=300, must-revalidate
/b2b/css/*
  Cache-Control: public, max-age=300, must-revalidate
/b2b/js/*
  Cache-Control: public, max-age=300, must-revalidate
/property/css/*
  Cache-Control: public, max-age=300, must-revalidate
/property/js/*
  Cache-Control: public, max-age=300, must-revalidate
/vacation/css/*
  Cache-Control: public, max-age=300, must-revalidate
/vacation/js/*
  Cache-Control: public, max-age=300, must-revalidate
/pos/css/*
  Cache-Control: public, max-age=300, must-revalidate
/pos/js/*
  Cache-Control: public, max-age=300, must-revalidate
/sanad/css/*
  Cache-Control: public, max-age=300, must-revalidate
/sanad/js/*
  Cache-Control: public, max-age=300, must-revalidate
/watad/css/*
  Cache-Control: public, max-age=300, must-revalidate
/watad/js/*
  Cache-Control: public, max-age=300, must-revalidate
/ask/css/*
  Cache-Control: public, max-age=300, must-revalidate
/ask/js/*
  Cache-Control: public, max-age=300, must-revalidate
/lahza/css/*
  Cache-Control: public, max-age=300, must-revalidate
/lahza/js/*
  Cache-Control: public, max-age=300, must-revalidate
/lahza/icons/*
  Cache-Control: public, max-age=86400, must-revalidate
/lahza/manifest.webmanifest
  Content-Type: application/manifest+json
  Cache-Control: public, max-age=300, must-revalidate
/lahza/sw.js
  Service-Worker-Allowed: /lahza/
  Cache-Control: public, max-age=0, must-revalidate
/marsad/css/*
  Cache-Control: public, max-age=300, must-revalidate
/marsad/js/*
  Cache-Control: public, max-age=300, must-revalidate
/nabta/css/*
  Cache-Control: public, max-age=300, must-revalidate
/nabta/js/*
  Cache-Control: public, max-age=300, must-revalidate
/tokens.css
  Cache-Control: public, max-age=604800
/assets/*
  Cache-Control: public, max-age=300, must-revalidate

# HTML - short cache so updates surface quickly
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Site CSS / JS at root. Files referenced with ?v= cache-bust params everywhere
# get a week; files loaded WITHOUT ?v= (script.js, demo.js, contact.js) stay at
# a day so updates still reach repeat visitors.
/home.css
  Cache-Control: public, max-age=604800
/home.app.js
  Cache-Control: public, max-age=604800
/home.fx.js
  Cache-Control: public, max-age=604800
/home.fx.css
  Cache-Control: public, max-age=604800
/styles.css
  Cache-Control: public, max-age=604800
/script.js
  Cache-Control: public, max-age=86400
/demo.css
  Cache-Control: public, max-age=604800
/demo.js
  Cache-Control: public, max-age=86400
/contact.js
  Cache-Control: public, max-age=86400

# Vendor libs - filenames carry the version, safe to cache long
/vendor/*
  Cache-Control: public, max-age=31536000, immutable

# Headshot - cache aggressively
/saad.png
  Cache-Control: public, max-age=31536000, immutable
/og.png
  Cache-Control: public, max-age=86400, must-revalidate

# SEO + discoverability files
/robots.txt
  Content-Type: text/plain
  Cache-Control: public, max-age=86400
/sitemap.xml
  Content-Type: application/xml
  Cache-Control: public, max-age=86400
/humans.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=86400
/.well-known/security.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=86400
