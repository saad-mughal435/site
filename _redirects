# Cloudflare Pages — URL rewrites/redirects
# https://developers.cloudflare.com/pages/configuration/redirects/

# If the live app's early auth gate ever fires before the bootstrap seeds
# the token, it tries to navigate to /login. Send it back to the app.
/login         /app/index.html  302
/logout        /app/index.html  302

# Friendly URLs
/cv            /contact.html    302
/resume        /contact.html    302
/take-demo     /demo.html       302

# Manzil Properties demo aliases
# Note: do NOT add /property/admin → /property/admin.html — Cloudflare Pages
# already serves admin.html when /property/admin is requested, and adding a
# redirect causes a loop (CF strips .html → 307 to /admin, our rule sent it
# back to /admin.html → loop).
/manzil          /property/index.html             302
/properties      /property/index.html             302
/list-property   /property/owner-onboard.html     302
/owner-dashboard /property/owner-dashboard.html   302

# Vacation Homes friendly aliases
/vacation-homes  /vacation/index.html          302
/stays           /vacation/index.html          302
/list-property   /vacation/host-onboard.html   302
/become-a-host   /vacation/host.html           302
/host-dashboard  /vacation/host-dashboard.html 302
