# Cloudflare Pages - URL rewrites/redirects
# https://developers.cloudflare.com/pages/configuration/redirects/

# If the live app's early auth gate ever fires before the bootstrap seeds
# the token, it tries to navigate to /login. Send it back to the app.
# These are genuinely temporary (auth state), so they stay 302.
/login         /app/index.html  302
/logout        /app/index.html  302

# NOTE: do NOT add an `/app/*  /app/index.html  200` SPA-fallback rule here.
# Cloudflare rejects it at deploy time as an infinite loop (it strips .html /
# /index from /app/index.html, which re-matches /app/* → loop) and FAILS THE
# WHOLE DEPLOY. Deep /app/ links are client-routed; a hard refresh on one
# falls through to the 404 page. A proper fix would be a Workers single-page
# -app asset handler, not a redirect rule.

# Friendly URLs - permanent vanity shortcuts, so 301 (consolidates link equity
# from anything that links /cv, /resume, etc. onto the real page).
/cv            /contact.html    301
/resume        /contact.html    301
/take-demo     /demo.html       301

# Manzil Properties demo aliases
# Note: do NOT add /property/admin → /property/admin.html - Cloudflare Pages
# already serves admin.html when /property/admin is requested, and adding a
# redirect causes a loop (CF strips .html → 307 to /admin, our rule sent it
# back to /admin.html → loop).
/manzil          /property/index.html             301
/properties      /property/index.html             301
/list-property   /property/owner-onboard.html     301
/owner-dashboard /property/owner-dashboard.html   301

# Vacation Homes friendly aliases
